<div class="group bg-white rounded-2xl border border-slate-200 shadow-sm hover:shadow-md hover:border-teal-300 mb-3 overflow-hidden">
    <a href="{full-link}" class="flex items-center gap-4 p-4">
        <div class="relative w-16 h-24 shrink-0 rounded-lg overflow-hidden shadow-sm border border-slate-100 bg-slate-100">
            [xfgiven_season_poster]
            <img src="[xfvalue_season_poster]" alt="{title}" class="w-full h-full object-cover">
            [/xfgiven_season_poster]
            <div class="absolute inset-0 bg-black/5"></div>
        </div>

        <div class="flex-grow min-w-0">
            <h4 class="text-lg font-bold text-slate-800 group-hover:text-teal-600 truncate">
                {season_number}. Sezon
            </h4>
            <div class="flex items-center gap-3 mt-1 text-sm text-slate-500 font-medium">
                [xfgiven_season_year]
                <span class="flex items-center gap-1">
                    <i class="fa-regular fa-calendar-check text-teal-500"></i> [xfvalue_season_year]
                </span>
                <span class="w-1 h-1 bg-slate-300 rounded-full"></span>
                [/xfgiven_season_year]
                <span class="flex items-center gap-1">
                    <i class="fa-solid fa-clapperboard text-slate-400"></i> Bölümleri İncele
                </span>
            </div>
        </div>
    </a>
</div>
